generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Property {
  id            String    @id @default(cuid())
  referenceCode String?   @unique
  title         String
  slug          String    @unique
  description   String    @db.Text
  operation     String
  type          String
  price         Float
  currency      String    @default("MXN")
  bedrooms      Int?
  bathrooms     Int?
  area          Float?
  lotArea       Float?
  parking       Int?
  yearBuilt     Int?
  city          String
  state         String    @default("Veracruz")
  country       String    @default("México")
  address       String?
  lat           Float?
  lng           Float?
  features      String?   @db.Text
  status        String    @default("available")
  featured      Boolean   @default(false)
  published     Boolean   @default(true)
  views         Int       @default(0)
  sourceType    String    @default("MANUAL")
  sourceFolder  String?
  sourceHash    String?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  photos    Photo[]
  inquiries Inquiry[]

  @@index([published, createdAt])
  @@index([city])
  @@map("properties")
}

model Photo {
  id         String   @id @default(cuid())
  url        String
  publicId   String?
  alt        String?
  order      Int      @default(0)
  isMain     Boolean  @default(false)
  propertyId String
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, order])
  @@map("photos")
}

model Inquiry {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  message    String   @db.Text
  propertyId String?
  honeypot   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([isRead, createdAt])
  @@map("inquiries")
}

model ImportJob {
  id                   String    @id @default(cuid())
  status               String    @default("PENDING")
  sourceType           String    @default("ADMIN_FOLDER")
  originalFilename     String?
  totalProperties      Int       @default(0)
  successfulProperties Int       @default(0)
  failedProperties     Int       @default(0)
  errors               String?   @db.Text
  createdById          String?
  startedAt            DateTime  @default(now())
  finishedAt           DateTime?
  createdAt             DateTime  @default(now())

  @@index([createdAt])
  @@map("import_jobs")
}
